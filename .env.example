# EdgeOS Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────
# NeonDB connection string — get yours from https://console.neon.tech
DB_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# Local PostgreSQL (Docker) — for offline-first operation and bidirectional sync
# This is the primary DB when available; falls back to Neon when offline.
# Uses port 5433 by default to avoid conflict with Homebrew Postgres on 5432.
LOCAL_DB_URL=postgresql+psycopg://edgeos:edgeos_local@localhost:5433/edgeos

# ── Replication ───────────────────────────────────────────────────────────
# Local Postgres settings (must match docker-compose.yml)
LOCAL_PG_HOST=localhost
LOCAL_PG_PORT=5433
LOCAL_PG_USER=edgeos
LOCAL_PG_PASSWORD=edgeos_local
LOCAL_PG_DATABASE=edgeos

# Replication user on Neon (create in Neon Console → Roles)
NEON_REPL_USER=replication_user
NEON_REPL_PASSWORD=

# ── Sync ─────────────────────────────────────────────────────────────────
# How often the sync sidecar pushes local changes to Neon (seconds)
# Only used when running in Docker (docker compose up)
SYNC_INTERVAL=5

# ── LLM Providers ───────────────────────────────────────────────────────
# OpenAI — required for embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Ollama Cloud — primary LLM provider
OLLAMA_API_KEY=...

# ── Security ─────────────────────────────────────────────────────────────
# Bearer token for API auth (all requests need Authorization: Bearer <key>)
# OS_SECURITY_KEY=...

# ── Scheduler ────────────────────────────────────────────────────────────
# Only one instance should run the scheduler when sharing a database.
# Set to "false" on all but one instance.
ENABLE_SCHEDULER=false

# ── Optional Tool API Keys ───────────────────────────────────────────────
# Uncomment and fill in to enable additional tools in the Studio Registry.
# EXA_API_KEY=
# LINKUP_API_KEY=
# TAVILY_API_KEY=
# SERPER_API_KEY=
# LINEAR_API_KEY=